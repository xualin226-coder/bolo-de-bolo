nfo"><a href="#loading" class="rounded-md"><article class="btn btn-outline btn-gray group h-full flex-col items-start justify-start rounded-md p-4 text-left"><div class="flex flex-row items-center gap-4"><div class="h-12 w-12 rounded-lg bg-gray-800 p-3"><svg width="1em" height="1em" class="h-full w-full text-white" data-icon="brand/paper"><symbol id="ai:local:brand/paper" viewBox="0 0 24 24"><path fill="#fff" d="M23.987 1.004 20.56 21.576a.86.86 0 0 1-.844.71.9.9 0 0 1-.322-.068l-6.067-2.477-3.24 3.95A.83.83 0 0 1 9.43 24a.8.8 0 0 1-.295-.054.85.85 0 0 1-.562-.803V18.47l11.57-14.184L5.827 16.674l-5.29-2.17A.85.85 0 0 1 0 13.768a.87.87 0 0 1 .429-.79L22.715.12a.83.83 0 0 1 .428-.12.853.853 0 0 1 .844 1.004"/></symbol><use href="#ai:local:brand/paper"></use></svg></div><h3 class="flex flex-1 items-center gap-4 text-lg font-medium">Paper</h3></div><p class="mt-4 font-normal">Paper is a Minecraft game server based on Spigot, designed to greatly improve performance and offer more advanced features and API.</p></article></a></software-preview><script type="module">globalThis.process??={},globalThis.process.env??={};var e=class extends HTMLElement{async connectedCallback(){let{software:e,previewType:t}=this.dataset;if(!e||!t)return;let n=this.querySelector(`a`);if(n)switch(t){case`Info`:n.href=`/software/${e}`;break;case`Download`:n.href=`/downloads/${e}`;break;case`Javadocs`:n.href=`https://jd.papermc.io/${e}`;break}}};customElements.define(`software-preview`,e);</script><software-preview data-software="velocity" data-preview-type="Info"><a href="#loading" class="rounded-md"><article class="btn btn-outline btn-gray group h-full flex-col items-start justify-start rounded-md p-4 text-left"><div class="flex flex-row items-center gap-4"><div class="h-12 w-12 rounded-lg bg-gray-800 p-3"><svg width="1em" height="1em" class="h-full w-full text-white" data-icon="brand/velocity"><symbol id="ai:local:brand/velocity" viewBox="0 0 34 34"><g fill="none"><g fill="#fff" clip-path="url(#